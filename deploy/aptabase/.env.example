# Copy to `.env` and fill in. Do NOT commit the real `.env`.
#
# Generate secrets on the VPS:
#   POSTGRES_PASSWORD / CLICKHOUSE_PASSWORD:  openssl rand -hex 16
#   AUTH_SECRET:                              openssl rand -base64 32

# Public dashboard URL — must match the NPM proxy host and your DNS record.
BASE_URL=https://analytics.viboplr.com

POSTGRES_PASSWORD=change-me
CLICKHOUSE_PASSWORD=change-me
AUTH_SECRET=change-me-32-chars-min

# SMTP for the dashboard sign-in magic link. OPTIONAL: leave blank and read the
# link from `docker compose logs aptabase` when you sign in (fine for one admin).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@viboplr.com
