{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browse-windows",
  "description": "Capability for browse windows opened by plugins",
  "windows": ["browse-*"],
  "remote": {
    "urls": ["https://*", "http://*"]
  },
  "permissions": [
    "core:default",
    "allow-browse-window-send"
  ]
}
