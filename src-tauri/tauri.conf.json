{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastPlayer",
  "version": "0.3.1",
  "identifier": "com.alex.fastplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "FastPlayer",
        "transparent": true,
        "width": 1024,
        "height": 700,
        "minWidth": 300,
        "minHeight": 80,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENENzU1MThDQUM1RURDNEYKUldSUDNGNnNqRkYxemV6SnJNeHJBcldOTVpxcjdkRTFYNDFmVFdralhvUWNSNTArenBwNXV1aFcK",
      "endpoints": [
        "https://github.com/outcast1000/fastplayer/releases/latest/download/latest.json"
      ]
    }
  }
}
